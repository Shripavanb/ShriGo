@page
@model PrivacyModel
@{
    ViewData["Title"] = "Privacy Policy";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ShriGo Privacy Policy</title>
    <link href="~/css/privacy.css" rel="stylesheet" />
</head>

<body>

    <div class="container">

        <h1>ShriGo Privacy Policy</h1>
        <div class="effective-date">Effective Date: 03May2026</div>

        <h2>1. Introduction</h2>
        <p>This Privacy Policy explains how ShriGo collects, uses, and protects your information when you use our platform.</p>

        <h2>2. Information We Collect</h2>

        <h3>2.1 Personal Information</h3>
        <ul>
            <li>Name, phone number, email address</li>
            <li>Account login details</li>
        </ul>

        <h3>2.2 Identity & Verification Data</h3>
        <ul>
            <li>Aadhaar details (for drivers)</li>
            <li>Vehicle registration and insurance documents</li>
        </ul>

        <h3>2.3 Usage & Technical Data</h3>
        <ul>
            <li>IP address</li>
            <li>Device and browser information</li>
            <li>App/website usage data</li>
        </ul>

        <h3>2.4 Location & Trip Data</h3>
        <ul>
            <li>Pickup and drop locations</li>
            <li>Trip history and ride details</li>
        </ul>

        <h2>3. How We Use Your Information</h2>
        <ul>
            <li>To provide and operate our services</li>
            <li>To verify users and ensure safety</li>
            <li>To manage bookings and rides</li>
            <li>To improve platform performance and user experience</li>
            <li>To communicate important updates and support</li>
        </ul>

        <h2>4. Data Sharing</h2>
        <p>We may share your data in the following cases:</p>
        <ul>
            <li>Between drivers and passengers for ride coordination</li>
            <li>With service providers supporting platform operations</li>
            <li>With legal authorities when required by law</li>
        </ul>

        <h2>5. Data Security</h2>
        <p>We implement reasonable technical and organizational measures to protect your data. However, no system can be guaranteed 100% secure.</p>

        <h2>6. Data Retention</h2>
        <p>We retain your data only as long as necessary to provide services and comply with legal obligations.</p>

        <h2>7. Your Rights</h2>
        <ul>
            <li>Access your personal data</li>
            <li>Request correction of inaccurate data</li>
            <li>Request deletion of your data</li>
            <li>Withdraw consent where applicable</li>
        </ul>

        <h2>8. Cookies & Tracking</h2>
        <p>ShriGo may use cookies and similar technologies to improve user experience and analyze platform usage.</p>

        <h2>9. Third-Party Links</h2>
        <p>Our platform may contain links to third-party websites. We are not responsible for their privacy practices.</p>

        <h2>10. Updates to This Policy</h2>
        <p>We may update this Privacy Policy from time to time. Continued use of the platform means you accept the updated policy.</p>

        <h2>11. Contact Us</h2>
        <p>
            Email: shrigopb@gmail.com<br>
            Website: <a href="https://shrigo.in">https://shrigo.in</a>
        </p>

        <footer>
            © 2026 ShriGo. All rights reserved.
        </footer>

    </div>

</body>
</html>

<!DOCTYPE html>
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Http

<html lang="en">
<head>
    <meta charset="utf-8"  />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"  />
    <meta property="og:title" content="ShriGo" />
    <meta property="og:url" content="https://shrigo.in" />
    <meta property="og:image"  content="~/img/shrigo_promotion_img.png" />
    <meta property="og:type" content="website" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="627" />
    <title>@ViewData["Title"] - ShriGo</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="https://googleapis.com"></script>
    <script src="https://jquery.com"></script>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <div class="row-2">
                <a class="navbar-brand" asp-area="" asp-page="/Index"><img src="~/img/ShriGo_Logo8.png" style="height:100px; width:150px" /></a>
                </div>
                <div class="row-4">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Privacy">Privacy</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/SignIn"><span id="signinBtn">SignIn</span></a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/SignUp"><span id="signupBtn">SignUp</span></a>
                        </li>
                    </ul>
                </div>
              </div>
                <div class="row-3">
                    <p>Welcome:<span id="userName">@Context.Session.GetString("session_UserName")</span></p>
                    @if(@Context.Session.GetString("session_UserRole") =="Driver")
                    {
                    <a class="nav-link text-dark" asp-area="" asp-page="/RiderProfile"><span id="riderprofileBtn">MyProfile</span></a>
                    }
                    else if(@Context.Session.GetString("session_UserRole") =="Passenger")
                    {
                    <a class="nav-link text-dark" asp-area="" asp-page="/Passengers/PassengerProfile"><span id="riderprofileBtn">MyProfile</span></a>
                    }
                    <a class="nav-link text-dark" asp-area="" asp-page="/SignOut"><span id="signoutBtn">SignOut</span></a>
                @{
                        var username = @Context.Session.GetString("session_UserName");
                 }
                @if (!string.IsNullOrEmpty(username))
                {
                    Console.WriteLine("SessionVissible:"+username);
                    <script>
                     /*-SigOutButton---*/
                     document.getElementById("userName").style.visibility ="visible";
                     document.getElementById("riderprofileBtn").style.visibility ="visible";
                     document.getElementById("signoutBtn").style.visibility ="visible";   

                     /*--SigUpButton--& SignInButton-Hidden-*/
                     document.getElementById("signupBtn").style.visibility ="hidden";
                     document.getElementById("signinBtn").style.visibility ="hidden";
                    </script>
               }
              else
                {
                    Console.WriteLine("Session****:"+username);
                  <script>
                    /*-SigOutButton---*/
                    document.getElementById("signoutBtn").style.visibility ="hidden";
                    document.getElementById("riderprofileBtn").style.visibility ="hidden";
                    document.getElementById("userName").innerText = "Guest";

                    /*--SigUpButton---*/
                    document.getElementById("signupBtn").style.visibility ="visible";
                    document.getElementById("signinBtn").style.visibility ="visible";
                  </script>
              }
                  
              </div>
         
               

            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    

@*     @if (User.Identity.IsAuthenticated)
    {
        <li class="nav-item">
            <a class="nav-link" asp-page="/SignOut">Sign Out</a>
        </li>
    } *@
    <br />
    <br />
    <br />
    <br />
    <!-----------Refrence-Row--------------->
    <div class="container-fluid referencebg">
        <div class="row">
            @* <hr style="border-top: 5px solid darkblue"  /> *@
            <div class="container">
                <div class="row">
                    <div class="col-md-3">
                        <!-----------Logo and Address ------->
                        <div class="row-cols-1">
                            <img src="~/img/ShriGo_Logo8.png" style="height:100px; width:150px" />
                        </div>
                        <div class="row-cols-1">
                            <p><span class="glyphicon glyphicon-map-marker text-warning p-3"></span>Sri Sai Enclave, Spring Fields Colony, Jeedimetla</p>
                            <p>Hyderabad, Telangana 500067, India</p>
                        </div>
                    </div>
                    <!-----------Social media------->
                    <div class="col-md-3">
                        <h3>Media</h3>
                        <hr />
                        <ul>
                            <li style="display:block"><a href="#" class="icon-link"><i class="bi bi-linkedin"></i></a></li>
                            <li style="display:block"><a href="https://www.instagram.com/shriaitech?igsh=MThicHV3NnVzMWlzZA==" target="_blank" class="icon-link"><i class="bi bi-instagram"> Instagram </i></a></li>
                            <li style="display:block"><a href="#" class="icon-link"><i class="bi bi-twitter"></i></a></li>
                            <li style="display:block"><a href="#" class="icon-link"><i class="bi bi-facebook"></i></a></li>
                        </ul>
                    </div>
                    <!-----------Company------->
                    <div class="col-md-3">
                        <h3>Company</h3>
                        <hr />
                        <ul>
                            <li style="display:block"><a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a></li>
                            <li style="display:block"><a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Products">Products</a></li>
                            <li style="display:block"><a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a></li>
                            <li style="display:block"><a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="ContactUs">Contact Us</a></li>
                            <li style="display:block"><a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="AboutUs" href="/AboutUs">About Us</a></li>
                        </ul>
                    </div>
                    <!-----------Contact Us------->
                    <div class="col-md-3">
                        <h3>Contact</h3>
                        <hr />
                        <ul>
                            <li style="display:block"><a><span class="glyphicon glyphicon-phone p-3"></span> +91 8374499001</a></li>
                            <li style="display:block"><a><span class="glyphicon glyphicon-envelope p-3"></span> shripavanb@shrigo.in</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <br />
    <br />
    <br />
    <!--------Footer-------------------->
    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - ShriGo -Powered by <a href="https://shriaitech.in/" target="_blank">shriaitech.in</a></a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>